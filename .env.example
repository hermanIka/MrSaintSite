# ============================================================
# Mr Saint - Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# ---- APPLICATION ----
NODE_ENV=production
PORT=5000
APP_URL=https://votre-domaine.com

# ---- BASE DE DONNÉES ----
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/mr_saint

# ---- SÉCURITÉ ----
# Générer avec : node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=VOTRE_SECRET_JWT_TRES_LONG_ET_ALEATOIRE

# ---- PAIEMENTS ----
PAWAPAY_API_TOKEN=votre_token_pawapay
MAISHAPAY_PUBLIC_KEY=votre_cle_publique_maishapay
MAISHAPAY_SECRET_KEY=votre_cle_secrete_maishapay

# ---- EMAIL (Resend) ----
RESEND_API_KEY=re_votre_cle_resend

# ---- CALENDLY ----
CALENDLY_API_KEY=votre_cle_calendly

# ---- CHATBOT (optionnel) ----
OPENAI_API_KEY=sk-votre_cle_openai

# ---- STOCKAGE FICHIERS ----
# Dossier où les uploads sont stockés (créé automatiquement)
UPLOADS_DIR=/var/www/mr-saint/uploads
